rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isSignedIn() { return request.auth != null; }

    function isValidUser(data) {
      return data.keys().hasAll(['name', 'email', 'createdAt'])
        && data.keys().size() == 3
        && data.name is string && data.name.size() > 0 && data.name.size() <= 100
        && data.email is string && data.email.size() > 0 && data.email.size() <= 100
        && data.createdAt is string && data.createdAt.size() <= 50;
    }

    match /users/{userId} {
      allow read: if isSignedIn() && request.auth.uid == userId;
      allow create: if isSignedIn() 
        && request.auth.uid == userId
        && isValidId(userId)
        && isValidUser(incoming());
      allow update: if isSignedIn()
        && request.auth.uid == userId
        && isValidId(userId)
        && isValidUser(incoming())
        && incoming().createdAt == existing().createdAt;
      allow delete: if false; // No deletion supported yet
    }
  }
}
